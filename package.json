{
  "name": "order-notification-distributed",
  "version": "1.0.0",
  "private": true,
  "description": "Distributed order-notification system — monorepo root",
  "workspaces": [
    "src/order-service",
    "src/notification-service",
    "src/inventory-service",
    "src/helpdesk-service",
    "src/shared",
    "infra"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "lint": "eslint . --ext .ts --max-warnings 0",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"**/*.{ts,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,json,md}\"",
    "test": "jest --passWithNoTests",
    "test:coverage": "jest --coverage --passWithNoTests",
    "test:ci": "jest --coverage --passWithNoTests --ci",
    "type-check": "tsc --noEmit -p tsconfig.json",
    "cdk": "cd infra && cdk",
    "cdk:synth": "cd infra && cdk synth",
    "cdk:diff": "cd infra && cdk diff",
    "clean": "npx rimraf dist cdk.out coverage .tsbuildinfo \"src/*/dist\" \"infra/dist\""
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "esbuild": "^0.25.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.31.0",
    "jest": "^29.7.0",
    "prettier": "^3.4.0",
    "rimraf": "^5.0.0",
    "ts-jest": "^29.2.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  }
}
