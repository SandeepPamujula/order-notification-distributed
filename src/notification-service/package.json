{
    "name": "@order-notification/notification-service",
    "version": "1.0.0",
    "private": true,
    "description": "Notification Service Lambda — processes SQS/Streams events and sends SES emails",
    "main": "dist/handler.js",
    "scripts": {
        "build": "esbuild src/handler.ts --bundle --platform=node --target=node22 --outdir=dist --sourcemap --external:@aws-sdk/* --minify --keep-names",
        "build:dev": "esbuild src/handler.ts --bundle --platform=node --target=node22 --outdir=dist --sourcemap --external:@aws-sdk/*",
        "type-check": "tsc --noEmit",
        "clean": "rimraf dist"
    },
    "dependencies": {
        "@aws-lambda-powertools/logger": "^2.0.0",
        "@aws-lambda-powertools/tracer": "^2.0.0",
        "@aws-sdk/client-dynamodb": "^3.0.0",
        "@aws-sdk/client-ses": "^3.0.0",
        "@aws-sdk/lib-dynamodb": "^3.0.0",
        "@aws-sdk/util-dynamodb": "^3.0.0",
        "zod": "^3.23.0"
    },
    "devDependencies": {
        "@types/aws-lambda": "^8.10.0",
        "aws-sdk-client-mock": "^4.0.0"
    }
}